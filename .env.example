# Site Configuration (client-side variables must be )
DOMAIN=example.com

# API Configuration (client-side accessible)
SITE_URL=http://localhost:4321
# URL for the Cloudflare Worker API
API_URL="http://localhost:8787"  # Development
# API_URL="https://api.example.com"  # Production

# hCaptcha Configuration (client-side safe)
# Site key for form validation - get yours at https://www.hcaptcha.com/
HCAPTCHA_SITE_KEY="your_hcaptcha_site_key_here"

AHREFS_KEY=your_key

# Notion Configuration (Server-side only - NEVER expose to client)
NOTION_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=195cff95e1ca81b8a298d3af2895090b
NOTION_PLATFORM_ID=ea2cff95e1ca82ab97128153e241fe9a
NOTION_DEFAULT_AUTHOR_ID=en/yuniel-acosta-perez
NOTION_DEFAULT_CATEGORY_ID=en/software-development
NOTION_DEFAULT_TAG_IDS=en/tech

# Notion Authors Sync
NOTION_AUTHORS_DATABASE_ID=your_notion_posts_database_id_here
NOTION_AUTHORS_NAME_PROPERTY=Author
NOTION_AUTHORS_LOCALE_PROPERTY=Locale
NOTION_AUTHORS_LOCALES=en

# Notion Taxonomy Sync
NOTION_TAXONOMY_DATABASE_ID=your_notion_posts_database_id_here
NOTION_TAXONOMY_TAGS_PROPERTY=Tags
NOTION_TAXONOMY_CATEGORIES_PROPERTY=Category
NOTION_TAXONOMY_LOCALES=en,es

# Run Notion sync in predev/prebuild
NOTION_SYNC=0

# Webhook Configuration (Server-side only - NEVER expose to client)
# Authentication headers for webhook endpoints
WEBHOOK_AUTH_TOKEN=your_auth_token_here
WEBHOOK_FORM_TOKEN_ID=your_form_token_id_here

# Webhook Endpoints (adjust these for your test/production environments)
CONTACT_WEBHOOK_URL=https://your-webhook-domain.com/webhook/v1/contact
NEWSLETTER_WEBHOOK_URL=https://your-webhook-domain.com/webhook/v1/portfolio/newsletter

# NOTION INTEGRATION CONFIG
# (kept above; no duplicates)
