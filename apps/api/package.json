{
	"name": "yap-api",
	"version": "0.0.5",
	"private": true,
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"build": "echo '🚀 Validating configuration...' && wrangler deploy --dry-run",
		"check": "pnpm test:unit && pnpm build",
		"clean": "rimraf dist .wrangler coverage",
		"deploy": "wrangler deploy",
		"dev": "PORTLESS_HTTPS=1 portless --name api --app-port 8787 wrangler dev",
		"start": "PORTLESS_HTTPS=1 portless --name api --app-port 8787 wrangler dev",
		"cf-typegen": "wrangler types",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run",
		"test:unit:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@hono/swagger-ui": "0.6.1",
		"@hono/zod-openapi": "1.2.2",
		"chanfana": "^3.2.1",
		"hono": "^4.12.7",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260312.1",
		"@types/node": "25.4.0",
		"@types/service-worker-mock": "^2.0.4",
		"@vitest/coverage-v8": "^4.0.18",
		"rimraf": "^6.1.3",
		"vitest": "^4.0.18",
		"wrangler": "catalog:"
	}
}
