{
	"name": "yap-api",
	"version": "0.0.8",
	"private": true,
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"build": "echo '🚀 Validating configuration...' && wrangler deploy --dry-run",
		"check": "pnpm test:unit && pnpm build",
		"clean": "rimraf dist .wrangler coverage",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev --host 127.0.0.1 --port 8787",
		"start": "wrangler dev --host 127.0.0.1 --port 8787",
		"cf-typegen": "wrangler types",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run",
		"test:unit:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@hono/swagger-ui": "catalog:",
		"@hono/zod-openapi": "catalog:",
		"chanfana": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:",
		"@types/node": "catalog:",
		"@types/service-worker-mock": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"rimraf": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:",
		"wrangler": "catalog:"
	}
}
