{
	"name": "yap-api",
	"version": "0.0.7",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "echo '🚀 Validating configuration...' && wrangler deploy --dry-run",
		"check": "pnpm test:unit && pnpm build",
		"clean": "rimraf dist .wrangler coverage",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev --host 127.0.0.1 --port 8787",
		"start": "wrangler dev --host 127.0.0.1 --port 8787",
		"cf-typegen": "wrangler types",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run",
		"test:unit:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@hono/swagger-ui": "0.6.1",
		"@hono/zod-openapi": "1.2.3",
		"chanfana": "^3.3.0",
		"hono": "^4.12.9",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260317.1",
		"@types/node": "25.5.0",
		"@types/service-worker-mock": "^2.0.4",
		"@vitest/coverage-v8": "^4.1.2",
		"rimraf": "^6.1.3",
		"vitest": "^4.1.2",
		"wrangler": "catalog:"
	}
}
