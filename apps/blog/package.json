{
	"name": "blog",
	"version": "0.0.20",
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"scripts": {
		"astro": "astro",
		"prebuild": "node ../../scripts/notion-prebuild-sync.mjs && pnpm notion:sync && pnpm notion:validate",
		"build": "cross-env BLOG_CONTENT_SOURCE=snapshot astro check && cross-env BLOG_CONTENT_SOURCE=snapshot astro build",
		"postbuild": "node ./scripts/update-csp-script-hashes.mjs",
		"build:fast": "cross-env BLOG_CONTENT_SOURCE=snapshot astro build",
		"postbuild:fast": "node ./scripts/update-csp-script-hashes.mjs",
		"check": "run-p check:*",
		"check:a11y": "biome lint --only=a11y ./src",
		"check:astro": "cross-env BLOG_CONTENT_SOURCE=snapshot astro check",
		"clean": "rimraf dist .astro coverage",
		"csp:hashes": "node ./scripts/update-csp-script-hashes.mjs",
		"notion:sync": "node ./scripts/run-notion-sync.mjs",
		"notion:validate": "node ./scripts/validate-notion-content.mjs",
		"predev": "node ../../scripts/notion-predev-sync.mjs",
		"dev": "astro dev --host 127.0.0.1 --port 4174",
		"organize": "node ./scripts/organize-articles.js",
		"preview": "astro preview --host 127.0.0.1 --port 4174",
		"start": "astro dev --host 127.0.0.1 --port 4174",
		"deploy": "astro build",
		"test": "run-p test:unit test:e2e",
		"test:unit": "vitest",
		"test:unit:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:chromium": "playwright test --project=chromium",
		"test:e2e:firefox": "playwright test --project=firefox",
		"test:e2e:webkit": "playwright test --project=webkit",
		"test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
		"test:e2e:report": "playwright show-report",
		"test:e2e:codegen": "playwright codegen http://127.0.0.1:4174"
	},
	"dependencies": {
		"@astrojs/check": "catalog:",
		"@astrojs/mdx": "catalog:",
		"@astrojs/partytown": "catalog:",
		"@astrojs/rss": "catalog:",
		"@astrojs/sitemap": "catalog:",
		"@jsdevtools/rehype-toc": "catalog:",
		"@notionhq/client": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@yap/astro-notion-loader": "workspace:*",
		"astro": "catalog:",
		"astro-compress": "catalog:",
		"astro-pagefind": "catalog:",
		"mdast-util-to-string": "catalog:",
		"notion-rehype-k": "catalog:",
		"pagefind": "catalog:",
		"rehype-katex": "catalog:",
		"rehype-slug": "catalog:",
		"rehype-stringify": "catalog:",
		"sharp": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"unified": "catalog:",
		"unist-util-visit": "catalog:",
		"unpic": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@axe-core/playwright": "catalog:",
		"@biomejs/biome": "catalog:",
		"@faker-js/faker": "catalog:",
		"@iconify-json/lucide": "catalog:",
		"@iconify-json/mdi": "catalog:",
		"@iconify-json/simple-icons": "catalog:",
		"@iconify-json/tabler": "catalog:",
		"@playwright/test": "catalog:",
		"@tailwindcss/typography": "catalog:",
		"@testing-library/dom": "catalog:",
		"@testing-library/preact": "catalog:",
		"@types/hast": "catalog:",
		"@types/mdast": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"astro-critters": "catalog:",
		"astro-icon": "catalog:",
		"clsx": "catalog:",
		"cross-env": "catalog:",
		"gray-matter": "catalog:",
		"happy-dom": "catalog:",
		"jsdom": "catalog:",
		"npm-run-all2": "catalog:",
		"preact-render-to-string": "catalog:",
		"reading-time": "catalog:",
		"rimraf": "catalog:",
		"satori": "catalog:",
		"tailwind-merge": "catalog:",
		"vfile": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
