---
import { render } from "astro:content";
import Layout from "@blog/layouts/Article.astro";
import { buildLocalizedArticlePaths } from "@blog/lib/article-localization";
import OptimizedPicture from "@/components/atoms/OptimizedPicture.astro";
import CtaNewsletterSubscription from "@/components/organisms/CtaNewsletterSubscription.astro";
import PostFooter from "@/components/organisms/PostFooter.astro";
import PostHeader from "@/components/organisms/PostHeader.astro";
import { getArticles } from "@/core/article";
import type Article from "@/core/article/article.model";
import {
	DEFAULT_LOCALE,
	type Lang,
	ROUTE_LOCALES,
	useTranslations,
} from "@/i18n";
import NotTranslateCaution from "@/i18n/components/NotTranslateCaution.astro";

const currentLocale = Astro.currentLocale as Lang;
const t = useTranslations(currentLocale);

interface Props {
	post: Article;
	usedLangs: Lang[];
}

export async function getStaticPaths() {
	const posts = await getArticles();
	return buildLocalizedArticlePaths(posts, ROUTE_LOCALES);
}

const { post, usedLangs } = Astro.props;

if (!post.entry) {
	throw new Error(`No entry found for post: ${post.id}`);
}

const { Content, remarkPluginFrontmatter } = await render(post.entry);

// Extract slug from post id (remove lang prefix)
const [_lang, ...slugParts] = post.id.split("/");
const postSlug = slugParts.join("/");
---

<Layout
	{...post}
	url={Astro.request.url}
	minutesRead={remarkPluginFrontmatter.minutesRead}
	enableComments={true}
	slug={postSlug}
>
	<div class="container mx-auto px-4 blog-shell">
		<NotTranslateCaution usedLangs={usedLangs} />
		<PostHeader post={post} readingTime={remarkPluginFrontmatter.minutesRead} />
		<div class="mx-auto prose lg:prose-xl dark:prose-invert blog-prose">
		{
			post.cover &&
				(typeof post.cover === "string" ? (
					<img src={post.cover} alt={post.title} width="1200" height="675" loading="eager" fetchpriority="high" decoding="async" style="aspect-ratio:16/9;object-fit:cover" class="mx-auto w-full max-w-full rounded-lg" />
				) : (
					<OptimizedPicture
						src={post.cover}
						alt={post.title}
						loading="eager"
						fetchpriority="high"
					/>
				))
		}
			<Content />
			<PostFooter post={post} />
		</div>
	</div>
	<div class="border-y border-y-secondary-foreground-light dark:border-y-secondary-foreground-dark mt-12">
		<CtaNewsletterSubscription
			formId="article-cta-newsletter-subscription-form"
			title={t("cta.title")}
			description={t("cta.description")}
			class="my-10 py-5 mx-auto container px-4"
		/>
	</div>

</Layout>
