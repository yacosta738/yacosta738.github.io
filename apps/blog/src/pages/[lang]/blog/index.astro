---


import BlogHero from "@blog/components/organisms/BlogHero.astro";
import Footer from "@blog/components/organisms/Footer.astro";
import Layout from "@blog/layouts/Layout.astro";
import ArticleCard from "@/components/molecules/ArticleCard.astro";
import BlogGridContainer from "@/components/molecules/BlogGridContainer.astro";
import Pagination from "@/components/molecules/Pagination.astro";
import { getArticles } from "@/core/article";
import { getExternalArticles } from "@/core/external-article";
import { type Lang, LOCALES, useTranslations } from "@/i18n";
import { type BlogPost, getBlogPostUrl } from "@/lib/blog-post.utils";

// Get locale from params
const { lang } = Astro.params;
const currentLocale = lang as Lang;
const t = useTranslations(currentLocale);

// Get and sort articles and external articles for the current language
const allArticles = await getArticles();
const allExternalArticles = await getExternalArticles();

// Combine both types and filter by language
const allBlogPosts: BlogPost[] = [
	...allArticles.filter((post) => post.id.split("/")[0] === currentLocale),
	...allExternalArticles.filter(
		(post) => post.id.split("/")[0] === currentLocale,
	),
];

// Sort by date (newest first)
const sortedArticles = allBlogPosts.sort(
	(a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf(),
);

const featuredPosts = allArticles
	.filter((post) => post.id.split("/")[0] === currentLocale && post.featured)
	.sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf())
	.slice(0, 3);
const featuredIds = new Set(featuredPosts.map((post) => post.id));
const visibleArticles = sortedArticles.filter(
	(post) => !featuredIds.has(post.id),
);

const title = t("blog.title");

export const getStaticPaths = () =>
	Object.keys(LOCALES).map((lang) => ({
		params: { lang },
	}));

const postsPerPage = 16;
const totalPages = Math.ceil(visibleArticles.length / postsPerPage);
const basePath = `/${currentLocale}/blog/page`;
const indexUrl = `/${currentLocale}/blog`;
---

<Layout {title}>
	<div class="container mx-auto px-4 blog-shell">
		<BlogHero title={title} currentLocale={currentLocale} />
		{featuredPosts.length > 0 && (
			<section class="blog-featured">
				<div class="blog-featured__header">
					<span class="blog-hero__kicker">
						{t({ en: "Featured", es: "Destacados" })}
					</span>
					<h2>{t({ en: "Top reads", es: "Lecturas clave" })}</h2>
				</div>
				<div class="blog-featured__grid">
					{featuredPosts.map((post) => (
						<ArticleCard
							image={post.cover}
							title={post.title}
							description={post.description}
							url={getBlogPostUrl(post, currentLocale)}
							loading="eager"
						/>
					))}
				</div>
			</section>
		)}
		<BlogGridContainer
			class="blog-grid blog-stagger"
			posts={visibleArticles.slice(0, postsPerPage)}
		/>
		<Pagination
			class="blog-pagination"
			currentPage={1}
			lastPage={totalPages}
			urlPrev={null}
			urlNext={totalPages > 1 ? `${basePath}/2` : null}
			basePath={basePath}
			maxDisplayedPages={5}
			firstPageUrl={indexUrl}
		/>
	</div>
	<Footer />
</Layout>
