---
import { buildBlogListing } from "@blog/lib/blog-listing";
import { getArticles } from "@/core/article";
import { getExternalArticles } from "@/core/external-article";
import { ROUTE_LOCALES } from "@/i18n";

export async function getStaticPaths() {
	const paths = [];
	const allArticles = await getArticles();
	const allExternalArticles = await getExternalArticles();
	const postsPerPage = 16;

	for (const lang of ROUTE_LOCALES) {
		const { visiblePosts } = buildBlogListing({
			articles: allArticles,
			externalArticles: allExternalArticles,
			locale: lang,
		});

		const totalPages = Math.ceil(visiblePosts.length / postsPerPage);

		for (let i = 2; i <= totalPages; i++) {
			const pagePosts = visiblePosts.slice(
				(i - 1) * postsPerPage,
				i * postsPerPage,
			);

			if (pagePosts.length === 0) continue;

			paths.push({
				params: {
					lang,
					page: i.toString(),
				},
			});
		}
	}

	return paths;
}

const search = new URL(Astro.request.url).search;
return Astro.redirect(
	`/${Astro.params.lang}/page/${Astro.params.page}${search}`,
	301,
);
---
