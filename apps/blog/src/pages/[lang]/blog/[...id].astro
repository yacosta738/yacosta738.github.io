---
import { getArticles } from "@/core/article";
import { DEFAULT_LOCALE, type Lang, ROUTE_LOCALES } from "@/i18n";

export async function getStaticPaths() {
	const posts = (await getArticles()).filter((post) => {
		const [lang] = post.id.split("/");
		return ROUTE_LOCALES.includes(lang as Lang);
	});

	const bySlug = new Map<string, Map<Lang, unknown>>();
	for (const post of posts) {
		const [lang, ...id] = post.id.split("/");
		const idPath = id.join("/");
		const langKey = lang as Lang;
		const entry = bySlug.get(idPath) ?? new Map<Lang, unknown>();
		entry.set(langKey, post);
		bySlug.set(idPath, entry);
	}

	const paths: Array<{ params: { lang: string; id: string } }> = [];

	for (const [idPath, langMap] of bySlug.entries()) {
		const availableLangs = Array.from(langMap.keys());
		const fallbackLang = (
			langMap.has(DEFAULT_LOCALE) ? DEFAULT_LOCALE : availableLangs[0]
		) as Lang;
		const fallbackPost = langMap.get(fallbackLang);
		if (!fallbackPost) {
			continue;
		}

		for (const lang of ROUTE_LOCALES) {
			paths.push({
				params: { lang, id: idPath },
			});
		}
	}

	return paths;
}

return Astro.redirect(
	`/${Astro.params.lang}/${Array.isArray(Astro.params.id) ? Astro.params.id.join("/") : Astro.params.id}${new URL(Astro.request.url).search}`,
	301,
);
---
