---
import { getAllArticlesIncludingExternal } from "@/core/article";
import { getTags } from "@/core/tag";
import { type Lang, ROUTE_LOCALES } from "@/i18n";

export async function getStaticPaths() {
	const paths = [];
	const allArticles = await getAllArticlesIncludingExternal();
	const postsPerPage = 16;

	for (const lang of ROUTE_LOCALES) {
		const tags = await getTags({ lang: lang as Lang });
		for (const tag of tags) {
			const tagArticles = allArticles
				.filter(
					(article) =>
						article.tags.some((tagItem) => tagItem.slug === tag.slug) &&
						article.id.startsWith(`${lang}/`),
				)
				.sort(
					(a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf(),
				);

			const totalPages = Math.ceil(tagArticles.length / postsPerPage);

			for (let i = 2; i <= totalPages; i++) {
				const pagePosts = tagArticles.slice(
					(i - 1) * postsPerPage,
					i * postsPerPage,
				);

				if (pagePosts.length > 0) {
					paths.push({
						params: {
							lang,
							tag: tag.slug,
							page: i.toString(),
						},
					});
				}
			}
		}
	}
	return paths;
}

const search = new URL(Astro.request.url).search;
return Astro.redirect(
	`/${Astro.params.lang}/tag/${Astro.params.tag}/page/${Astro.params.page}${search}`,
	301,
);
---
