---
import { getAllArticlesIncludingExternal } from "@/core/article";
import { getTagSlug, getTags } from "@/core/tag";
import { type Lang, ROUTE_LOCALES } from "@/i18n";

export async function getStaticPaths() {
	const paths = [];
	const allArticles = await getAllArticlesIncludingExternal();

	for (const lang of ROUTE_LOCALES) {
		const tags = await getTags({ lang: lang as Lang });
		for (const tag of tags) {
			const tagSlug = getTagSlug(tag);
			const tagArticles = allArticles.filter(
				(article) =>
					article.tags.some((tagItem) => getTagSlug(tagItem) === tagSlug) &&
					article.id.startsWith(`${lang}/`),
			);

			if (tagArticles.length > 0) {
				paths.push({
					params: {
						lang: lang,
						tag: tagSlug,
					},
				});
			}
		}
	}
	return paths;
}

return Astro.redirect(
	`/${Astro.params.lang}/tag/${Astro.params.tag}/${new URL(Astro.request.url).search}`,
	301,
);
---
