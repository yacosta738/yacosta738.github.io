---
import { getArticles } from "@/core/article";
import { DEFAULT_LOCALE } from "@/i18n";

export async function getStaticPaths() {
	const posts = await getArticles();
	const langPrefix = `${DEFAULT_LOCALE}/`;

	return posts
		.filter((post) => post.id.startsWith(langPrefix))
		.map((post) => {
			const [, ...id] = post.id.split("/");
			const idPath = id.join("/");
			return { params: { id: idPath } };
		});
}

const search = new URL(Astro.request.url).search;
const { id } = Astro.params;
const path = Array.isArray(id) ? id.join("/") : id;
return Astro.redirect(`/${path}${search}`, 301);
---
