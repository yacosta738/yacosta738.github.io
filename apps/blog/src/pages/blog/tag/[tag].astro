---
import { getAllArticlesIncludingExternal } from "@/core/article";
import { getTags } from "@/core/tag";
import { DEFAULT_LOCALE, type Lang } from "@/i18n";

export async function getStaticPaths() {
	const paths = [];
	const allArticles = await getAllArticlesIncludingExternal();
	const lang: Lang = DEFAULT_LOCALE;
	const tags = await getTags({ lang });

	for (const tag of tags) {
		const tagArticles = allArticles.filter(
			(article) =>
				article.tags.some((tagItem) => tagItem.slug === tag.slug) &&
				article.id.startsWith(`${lang}/`),
		);

		if (tagArticles.length > 0) {
			paths.push({
				params: {
					tag: tag.slug,
				},
			});
		}
	}
	return paths;
}

return Astro.redirect(
	`/tag/${Astro.params.tag}${new URL(Astro.request.url).search}`,
	301,
);
---
