---
import { getAllArticlesIncludingExternal } from "@/core/article";
import { getTagSlug, getTags } from "@/core/tag";
import { DEFAULT_LOCALE, type Lang } from "@/i18n";

export async function getStaticPaths() {
	const paths = [];
	const allArticles = await getAllArticlesIncludingExternal();
	const postsPerPage = 16;
	const lang: Lang = DEFAULT_LOCALE;
	const tags = await getTags({ lang });

	for (const tag of tags) {
		const tagSlug = getTagSlug(tag);
		const tagArticles = allArticles
			.filter(
				(article) =>
					article.tags.some((tagItem) => getTagSlug(tagItem) === tagSlug) &&
					article.id.startsWith(`${lang}/`),
			)
			.sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

		const totalPages = Math.ceil(tagArticles.length / postsPerPage);

		for (let i = 2; i <= totalPages; i++) {
			const pagePosts = tagArticles.slice(
				(i - 1) * postsPerPage,
				i * postsPerPage,
			);

			if (pagePosts.length > 0) {
				paths.push({
					params: {
						tag: tagSlug,
						page: i.toString(),
					},
				});
			}
		}
	}
	return paths;
}

return Astro.redirect(
	`/tag/${Astro.params.tag}/page/${Astro.params.page}${new URL(Astro.request.url).search}`,
	301,
);
---
