---
import PageHeadline from "@/components/atoms/PageHeadline.astro";
import TextAnimation from "@/components/atoms/TextAnimation.astro";
import { type Lang, useTranslatedPath, useTranslations } from "@/i18n";

type Props = {
	title: string;
	currentLocale: Lang;
};

const { title, currentLocale } = Astro.props as Props;
const t = useTranslations(currentLocale);
const translatePath = useTranslatedPath(currentLocale);
---

<section class="blog-hero">
	<div class="blog-hero__content">
		<TextAnimation effect="per-character-rise" tag="span" delay={0}>
			<span class="blog-hero__kicker">
				{t({ en: "Technical journal", es: "Diario técnico" })}
			</span>
		</TextAnimation>
		<PageHeadline class="blog-headline" {title}>
			<TextAnimation effect="line-by-line-slide" tag="span" delay={200}>
				<span>
					{
						t({
							en: "Deep dives, engineering notes, and lessons learned from building.",
							es: "Análisis, notas de ingeniería y aprendizajes reales de construir.",
						})
					}
				</span>
			</TextAnimation>
		</PageHeadline>

		<div class="blog-hero__actions">
			<TextAnimation effect="micro-scale-fade" tag="span" delay={260}>
				<a class="blog-pill" href={translatePath("/search/")}>
					{t("search.title")}
				</a>
			</TextAnimation>
			<TextAnimation effect="micro-scale-fade" tag="span" delay={320}>
				<a class="blog-pill" href={translatePath("/tag/")}>
					{t("tags.title")}
				</a>
			</TextAnimation>
			<TextAnimation effect="micro-scale-fade" tag="span" delay={380}>
				<a class="blog-pill" href={translatePath("/category/")}>
					{t("categories.title")}
				</a>
			</TextAnimation>
		</div>
	</div>
</section>
