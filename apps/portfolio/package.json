{
	"name": "portfolio",
	"version": "0.0.17",
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"scripts": {
		"astro": "astro",
		"build": "cross-env NOTION_LOADER=0 astro check && cross-env NOTION_LOADER=0 astro build",
		"build:fast": "cross-env NOTION_LOADER=0 astro build",
		"check": "run-p check:*",
		"check:a11y": "biome lint --only=a11y ./src",
		"check:astro": "cross-env NOTION_LOADER=0 astro check",
		"clean": "rimraf dist .astro coverage",
		"csp:hashes": "node ./scripts/update-csp-script-hashes.mjs",
		"dev": "cross-env NOTION_LOADER=0 astro dev --host 127.0.0.1 --port 4173",
		"organize": "node ./scripts/organize-articles.js",
		"preview": "cross-env NOTION_LOADER=0 astro preview --host 127.0.0.1 --port 4173",
		"start": "cross-env NOTION_LOADER=0 astro dev --host 127.0.0.1 --port 4173",
		"deploy": "cross-env NOTION_LOADER=0 astro build",
		"test": "run-p test:unit test:e2e",
		"test:unit": "vitest",
		"test:unit:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:chromium": "playwright test --project=chromium",
		"test:e2e:firefox": "playwright test --project=firefox",
		"test:e2e:webkit": "playwright test --project=webkit",
		"test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
		"test:e2e:report": "playwright show-report",
		"test:e2e:codegen": "playwright codegen http://127.0.0.1:4173"
	},
	"dependencies": {
		"@astrojs/check": "catalog:",
		"@astrojs/mdx": "catalog:",
		"@astrojs/partytown": "catalog:",
		"@astrojs/rss": "catalog:",
		"@astrojs/sitemap": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"astro": "catalog:",
		"astro-compress": "catalog:",
		"astro-pagefind": "catalog:",
		"mdast-util-to-string": "catalog:",
		"pagefind": "catalog:",
		"sharp": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"unist-util-visit": "catalog:",
		"unpic": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@axe-core/playwright": "catalog:",
		"@biomejs/biome": "catalog:",
		"@faker-js/faker": "catalog:",
		"@iconify-json/lucide": "catalog:",
		"@iconify-json/mdi": "catalog:",
		"@iconify-json/simple-icons": "catalog:",
		"@iconify-json/tabler": "catalog:",
		"@playwright/test": "catalog:",
		"@tailwindcss/typography": "catalog:",
		"@testing-library/dom": "catalog:",
		"@testing-library/preact": "catalog:",
		"@types/hast": "catalog:",
		"@types/mdast": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"astro-critters": "catalog:",
		"astro-icon": "catalog:",
		"clsx": "catalog:",
		"cross-env": "catalog:",
		"gray-matter": "catalog:",
		"happy-dom": "catalog:",
		"jsdom": "catalog:",
		"npm-run-all2": "catalog:",
		"preact-render-to-string": "catalog:",
		"reading-time": "catalog:",
		"rimraf": "catalog:",
		"satori": "catalog:",
		"tailwind-merge": "catalog:",
		"unified": "catalog:",
		"vfile": "catalog:",
		"vitest": "catalog:"
	}
}
