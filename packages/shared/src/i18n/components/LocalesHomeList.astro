---
/**
 * LocalesHomeList component.
 * This component generates a list (`<li>`) of links to the homepage of each
 * available language. It is likely intended for use on a 404 page or a
 * dedicated language selection page. It does not accept any props.
 */
import { type Lang, LOCALES, useTranslatedPath } from "@/i18n";
---

{
  (Object.entries(LOCALES) as Array<[Lang, (typeof LOCALES)[Lang]]>).map(
    ([lang, { label }]) => {
      const translatePath = useTranslatedPath(lang);
      const href = translatePath("/");

      return (
        <li>
          <a
            href={href}
            onclick={`localStorage.selectedLang = "${lang}"`}
            dir={LOCALES[lang].dir || null}
          >
            {label}
          </a>
        </li>
      );
    },
  )
}
