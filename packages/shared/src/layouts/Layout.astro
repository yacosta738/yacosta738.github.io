---
/**
 * Main layout component for all pages.
 * This component sets up the basic HTML document structure, including the <head>
 * and <body>, and includes global styles, scripts, and common UI elements.
 *
 * It handles:
 * - SEO metadata (title, description, Open Graph, Twitter cards).
 * - Theme switching logic (with an inline script to prevent FOUC).
 * - Favicons and manifest links.
 * - Common components like the Header, Analytics, and various effects.
 * - The main content slot for individual pages.
 *
 * @prop {string} [title] - The title of the page, which will be combined with the site title.
 */
import Analytics from "@/components/atoms/Analytics.astro";
import Header from "@/components/organisms/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE, X_ACCOUNT } from "@/configs/site.consts";
import { getMainResumeWithData } from "@/core/resume/resume/resume.service";
import {
	getLocalePathsEnhanced,
	type Lang,
	LOCALES,
	useTranslations,
} from "@/i18n";
import "@/styles/global.css";

import { ClientRouter } from "astro:transitions";
import AppScripts from "@/components/atoms/AppScripts.astro";
import Technologies from "@/components/atoms/Technologies.astro";
import TorchEffect from "@/components/atoms/TorchEffect.astro";
import {
	DARK_COLOR,
	HEADER_ID,
	LIGHT_COLOR,
	STORAGE_KEY,
} from "@/configs/theme.consts";
import LocaleSuggest from "@/i18n/components/LocaleSuggest.astro";
import { safeJsonLd } from "@/lib/seo/json-ld";
import { resolvePublicOrigin } from "@/utils/public-origin";
import alkatraRegularWoff2 from "../assets/font/alkatra/alkatra-v3-latin-regular.woff2";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string | URL;
	showSearch?: boolean;
	/** Set to "article" for blog posts, defaults to "website" */
	ogType?: "website" | "article";
	/** ISO date string for article publish date */
	articlePublishedTime?: string;
	/** ISO date string for article last modified date */
	articleModifiedTime?: string;
	/** Author profile URL for article OG tags */
	articleAuthorUrl?: string;
	/** Tags for article OG tags */
	articleTags?: string[];
	/** When true, Layout skips rendering its own <main> (page provides its own) */
	hasOwnMain?: boolean;
	/** OG image width (only emitted when explicitly provided) */
	ogImageWidth?: number;
	/** OG image height (only emitted when explicitly provided) */
	ogImageHeight?: number;
	/** OG image MIME type (only emitted when explicitly provided) */
	ogImageType?: string;
}
const {
	title = "",
	description = "",
	ogImage = "",
	showSearch: showSearchProp,
	ogType = "website",
	articlePublishedTime,
	articleModifiedTime,
	articleAuthorUrl,
	articleTags = [],
	hasOwnMain = false,
	ogImageWidth,
	ogImageHeight,
	ogImageType,
} = Astro.props;
const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const resume = (await getMainResumeWithData()) ?? {
	basics: {
		image: "",
		summary: t("default.summary"),
		url: Astro.site?.href || "",
	},
};

const pageTitle = title.trim();
const basicsName = (resume.basics as { name?: string }).name?.trim();
const brandLabel = basicsName || "Yuniel Acosta";
const brandedTitle = pageTitle ? `${pageTitle} | ${brandLabel}` : "";
const localeTitle = pageTitle
	? brandedTitle.length <= 60
		? brandedTitle
		: pageTitle.length > 60
			? `${pageTitle.slice(0, 57).trimEnd()}…`
			: pageTitle
	: t(SITE_TITLE);
const { image, summary, url } = resume.basics;
const rawMetaDescription = description || summary || t("default.summary");
const metaDescription =
	rawMetaDescription.length > 160
		? `${rawMetaDescription.slice(0, 157).trimEnd()}…`
		: rawMetaDescription;

// Extract the image URL from ImageMetadata if needed
const getImageUrl = (
	img: string | { src: string } | null | undefined,
): string => {
	if (!img) return "";
	if (typeof img === "string") return img;
	if (typeof img === "object" && "src" in img) return img.src;
	return "";
};

const imageUrl = getImageUrl(image as string | { src: string });

// Resolve a single og:image URL. Preference order:
// 1. ogImage prop (string or URL)
// 2. resume.basics.image
// Returns an absolute URL string or an empty string.
const resolveOgImage = (candidate?: string | URL) => {
	if (!candidate && !imageUrl) return "";
	try {
		if (candidate) return new URL(String(candidate), Astro.url).href;
	} catch {
		// fallthrough to try resume image
	}
	try {
		return imageUrl ? new URL(imageUrl, Astro.url).href : "";
	} catch {
		return "";
	}
};
const ogImageUrl = resolveOgImage(ogImage as string | URL);

const getHostname = (urlStr?: string) => {
	if (!urlStr) return "";
	try {
		return new URL(urlStr).hostname;
	} catch {
		return "";
	}
};

const isValidAbsoluteUrl = (value?: string): value is string => {
	if (!value) return false;
	try {
		const parsed = new URL(value);
		return parsed.protocol === "http:" || parsed.protocol === "https:";
	} catch {
		return false;
	}
};

const fallbackOrigin = resolvePublicOrigin(
	Astro.site,
	Astro.request,
	Astro.url,
);
const alternatesOrigin = fallbackOrigin;

const normalizedPathname = Astro.url.pathname.replaceAll(/\/{2,}/g, "/");
const canonicalHref = fallbackOrigin
	? new URL(normalizedPathname, fallbackOrigin).href
	: Astro.url.href;
const localePaths = await getLocalePathsEnhanced(
	new URL(normalizedPathname, Astro.url.origin),
);
const xDefaultPath =
	localePaths.find((props) => props.lang === "en")?.path ||
	localePaths.find((props) => props.lang === locale)?.path ||
	"/";
const showSearch = typeof showSearchProp === "boolean" ? showSearchProp : false;
const xAccount =
	typeof X_ACCOUNT === "string"
		? X_ACCOUNT
		: X_ACCOUNT[locale] || X_ACCOUNT.en || "";
const siteName = typeof SITE_TITLE === "string" ? SITE_TITLE : t(SITE_TITLE);
const siteDescription =
	typeof SITE_DESCRIPTION === "string"
		? SITE_DESCRIPTION
		: SITE_DESCRIPTION[locale] || SITE_DESCRIPTION.en || metaDescription;
const localeTag = LOCALES[locale].lang || locale;
---

<!doctype html>
<html lang={LOCALES[locale].lang || locale} dir={LOCALES[locale].dir || "ltr"}>
  <head>
    <meta charset="UTF-8" />
    <title>{localeTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" id="theme-color" content={LIGHT_COLOR} />
    <meta name="ahrefs-site-verification" content="a8baee35306c6c6f73d8e1b8862eb8fc3f0a8099a652bdc85323415a4707731a" />

    <!-- Optimized inline theme script - View Transitions supported -->
    <script is:inline define:vars={{ STORAGE_KEY, LIGHT_COLOR, DARK_COLOR }}>
      const initTheme = () => {
        const getPreferredTheme = () => {
          try {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored === "dark" || stored === "light") return stored;
          } catch {}
          return matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        };
        
        const applyTheme = (theme) => {
          const docEl = document.documentElement;
          const metaColor = document.getElementById("theme-color");
          if (theme === "dark") {
            docEl.classList.add("dark");
            if (metaColor) metaColor.setAttribute("content", DARK_COLOR);
            document.dispatchEvent(new CustomEvent("themeChanged", { detail: { theme: "dark" } }));
          } else {
            docEl.classList.remove("dark");
            if (metaColor) metaColor.setAttribute("content", LIGHT_COLOR);
            document.dispatchEvent(new CustomEvent("themeChanged", { detail: { theme: "light" } }));
          }
        };
        
        const currentTheme = getPreferredTheme();
        applyTheme(currentTheme);
        
        window.themeSystem = {
          toggle() {
            const current = document.documentElement.classList.contains("dark") ? "dark" : "light";
            const next = current === "dark" ? "light" : "dark";
            applyTheme(next);
            try { localStorage.setItem(STORAGE_KEY, next); } catch {}
          },
          clear() {
            try { localStorage.removeItem(STORAGE_KEY); } catch {}
            applyTheme(getPreferredTheme());
          }
        };
      };

      const syncThemeToIncomingDocument = (newDocument) => {
        if (!newDocument?.documentElement) return;

        const isDark = document.documentElement.classList.contains("dark");
        newDocument.documentElement.classList.toggle("dark", isDark);

        const incomingThemeColor = newDocument.getElementById("theme-color");
        if (incomingThemeColor) {
          incomingThemeColor.setAttribute("content", isDark ? DARK_COLOR : LIGHT_COLOR);
        }
      };

      initTheme();

      document.addEventListener('astro:before-swap', (event) => {
        syncThemeToIncomingDocument(event.newDocument);
      });

      document.addEventListener('astro:after-swap', initTheme);

      matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
        try {
          if (!localStorage.getItem(STORAGE_KEY)) {
            const theme = e.matches ? "dark" : "light";
            const docEl = document.documentElement;
            if (theme === "dark") docEl.classList.add("dark");
            else docEl.classList.remove("dark");
          }
        } catch {}
      });
    </script>

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Preload critical fonts to reduce render blocking -->
    <link rel="preload" href={alkatraRegularWoff2} as="font" type="font/woff2" crossorigin />

    <!-- DNS prefetch and preconnect for Cloudflare optimization -->
    <link rel="dns-prefetch" href="https://analytics.ahrefs.com" />
    <link rel="preconnect" href="https://cloudflareinsights.com" crossorigin />

    <!-- Preconnect for hCaptcha (critical for contact form performance) -->
    <link rel="preconnect" href="https://js.hcaptcha.com" crossorigin />
    <link rel="preconnect" href="https://api.hcaptcha.com" crossorigin />
    <link rel="dns-prefetch" href="https://newassets.hcaptcha.com" />

    <!-- SEO: Canonical URL (clean, without query parameters) -->
    <link rel="canonical" href={canonicalHref} />

    <!-- Additional SEO meta tags -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content={(resume.basics as { name?: string })?.name || "Yuniel Acosta"} />
    <ClientRouter />

    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternatesOrigin &&
      localePaths.map((props) => (
        <link
          rel="alternate"
          hreflang={LOCALES[props.lang].lang || props.lang}
          href={`${alternatesOrigin}${props.path}`}
        />
      ))}
    {alternatesOrigin && <link rel="alternate" hreflang="x-default" href={`${alternatesOrigin}${xDefaultPath}`} />}

    <!-- Open Graph -->
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={localeTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={localeTag.replace("-", "_")} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageUrl && ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    {ogImageUrl && ogImageType && <meta property="og:image:type" content={ogImageType} />}

    <!-- Article-specific OG tags -->
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === "article" && isValidAbsoluteUrl(articleAuthorUrl) && (
      <meta property="article:author" content={articleAuthorUrl} />
    )}
    {ogType === "article" && articleTags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:domain" content={getHostname(canonicalHref)} />
    <meta name="twitter:url" content={canonicalHref} />
    <meta name="twitter:title" content={localeTitle} />
    <meta name="twitter:description" content={metaDescription} />
    {xAccount && <meta name="twitter:site" content={xAccount} />}
    {xAccount && <meta name="twitter:creator" content={xAccount} />}
    <meta
      name="twitter:image"
      content={ogImageUrl || (imageUrl ? new URL(imageUrl, Astro.url).href : "")}
    />

    <!-- JSON-LD: WebSite schema (all pages) -->
    <script type="application/ld+json" set:html={safeJsonLd({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": siteName,
      "url": fallbackOrigin || canonicalHref,
      "description": siteDescription,
      "inLanguage": localeTag,
    })} />

    <!-- Slot for page-specific JSON-LD (e.g., BlogPosting) -->
    <slot name="head" />
  </head>
  <body>
    <LocaleSuggest />
    <slot name="header">
      <Header id={HEADER_ID} showSearch={showSearch} />
    </slot>
    <slot name="subheader" />
    {hasOwnMain ? (
      <slot />
    ) : (
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
    )}
    <slot name="aside" />
    <slot name="json-ld" />
    <Analytics />
    <Technologies />
    <AppScripts />
    <TorchEffect />
  </body>
</html>
