---
import ToTopButton from "@/components/atoms/ToTopButton.astro";
import HeaderProgressBar from "@/components/molecules/HeaderProgressBar.astro";
import BlogFooter from "@/components/organisms/BlogFooter.astro";
import Comments from "@/components/organisms/Comments.astro";
import WidgetWrapper from "@/components/organisms/WidgetWrapper.astro";
import type Article from "@/core/article/article.model";
import { type Lang, useTranslations } from "@/i18n";
import BaseLayout from "@/layouts/Layout.astro";
import { getOgImagePath } from "@/lib/open-graph/og.service";
import { resolvePublicOrigin } from "@/utils/public-origin";

interface Props extends Article {
	url: string;
	minutesRead: string;
	/** Enable comments section (default: false) */
	enableComments?: boolean;
	/** Slug for comment thread mapping */
	slug?: string;
}

const {
	title,
	description,
	author,
	tags = [],
	date,
	lastModified,
	cover,
	category,
	url = Astro.request.url,
	minutesRead,
	enableComments = false,
	slug,
} = Astro.props;

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);
const DEFAULT_AUTHOR = "Yuniel Acosta";
const authorName = author?.name || DEFAULT_AUTHOR;
const publicOrigin = resolvePublicOrigin(Astro.site, Astro.request, Astro.url);

const ogImage = publicOrigin
	? new URL(getOgImagePath(Astro.url.pathname), publicOrigin).href
	: "";

// Resolve cover image URL for JSON-LD
const getCoverUrl = (img: typeof cover): string => {
	if (!img) return ogImage;
	if (typeof img === "string")
		return img.startsWith("http") ? img : new URL(img, publicOrigin).href;
	if (typeof img === "object" && "src" in img)
		return new URL(img.src, publicOrigin).href;
	return ogImage;
};

// Build locale-aware origin and canonical URL
const siteOrigin = publicOrigin;
const canonicalUrl = `${siteOrigin}${Astro.url.pathname}`;

// Locale-aware base path (e.g., "" for default, "/es" for Spanish)
const localePrefix =
	Astro.url.pathname.match(/^\/([a-z]{2})\//)?.[0]?.slice(0, -1) || "";
const localizedHome = `${siteOrigin}${localePrefix}/`;
const localizedBlog = `${siteOrigin}${localePrefix}/blog`;
const authorProfileUrl =
	publicOrigin && author?.slug
		? new URL(`${localePrefix}/author/${author.slug}`, `${publicOrigin}/`).href
		: undefined;

/** Safely serialize JSON-LD, escaping `<` to prevent `</script>` breakout */
const safeJsonLd = (data: Record<string, unknown>): string =>
	JSON.stringify(data).replace(/</g, "\\u003c");

// BlogPosting JSON-LD structured data
const blogPostingJsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description: description,
	image: getCoverUrl(cover),
	url: canonicalUrl,
	datePublished: date?.toISOString(),
	...(lastModified && { dateModified: lastModified.toISOString() }),
	author: {
		"@type": "Person",
		name: authorName,
		...(author?.url && { url: author.url }),
	},
	publisher: {
		"@type": "Person",
		name: authorName,
	},
	...(category && {
		articleSection: category.title,
	}),
	...(tags.length > 0 && {
		keywords: tags.map((tag) => tag.title).join(", "),
	}),
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonicalUrl,
	},
};

// BreadcrumbList JSON-LD (locale-aware)
const breadcrumbJsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: t({ en: "Home", es: "Inicio" }) || "Home",
			item: localizedHome,
		},
		{
			"@type": "ListItem",
			position: 2,
			name: "Blog",
			item: localizedBlog,
		},
		{
			"@type": "ListItem",
			position: 3,
			name: title,
			item: canonicalUrl,
		},
	],
};
---

<BaseLayout
	{title}
	{description}
	{ogImage}
	showSearch={true}
	ogType="article"
	articlePublishedTime={date?.toISOString()}
	articleModifiedTime={lastModified?.toISOString()}
	articleAuthorUrl={authorProfileUrl}
	articleTags={tags.map((tag) => tag.title)}
	ogImageWidth={1200}
	ogImageHeight={630}
	ogImageType="image/png"
>
	<HeaderProgressBar
		slot="subheader"
		title={title}
		description={description}
		url={url}
		tags={tags.map((tag) => tag.title)}
		minutesRead={minutesRead}
	/>
	<div class="container mx-auto px-4 lg:px-12 flex flex-col lg:flex-row gap-8 py-28">
		<article class="flex-1 lg:basis-3/4" data-pagefind-body>
			<slot />
			
			<!-- Comments Section (if enabled) -->
			{enableComments && slug && (
				<Comments 
					slug={slug} 
					locale={Astro.currentLocale as Lang}
					class="mt-12"
					data-pagefind-ignore
				/>
			)}
		</article>
		<aside class="w-full lg:w-80 lg:sticky lg:top-8 lg:self-start" data-pagefind-ignore>
			<WidgetWrapper />
		</aside>
	</div>
	<BlogFooter />
	<ToTopButton />

	<!-- BlogPosting + BreadcrumbList JSON-LD -->
	<script slot="head" type="application/ld+json" set:html={safeJsonLd(blogPostingJsonLd)} />
	<script slot="head" type="application/ld+json" set:html={safeJsonLd(breadcrumbJsonLd)} />
</BaseLayout>
