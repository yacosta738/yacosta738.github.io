---
import { Icon } from "astro-icon/components";
import OptimizedPicture from "@/components/atoms/OptimizedPicture.astro";
import AuthorSocials from "@/components/molecules/AuthorSocials.astro";
import type { Social } from "@/core/author";
import { findImage } from "@/utils/images";

interface Props {
	name: string;
	email: string;
	avatar: string;
	location: string;
	socials: Social[];
}

const { name, email, avatar, location, socials } = Astro.props;

const preparedImage = await findImage(avatar || "");
---

<div class="blog-author-card">
    <OptimizedPicture
        src={preparedImage as unknown as any}
        alt={name}
        class="blog-author-avatar"
        loading="eager"
    />
    <div class="blog-author-card__meta">
        <h1 class="blog-author-name">{name}</h1>
        <div class="blog-author-location">
            <Icon name="lucide:map-pin" class="blog-author-location__icon" />
            {location}
        </div>
        <AuthorSocials socials={socials} email={email} className="blog-author-socials" />
    </div>
</div>
