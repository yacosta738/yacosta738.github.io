---
import type { HTMLAttributes } from "astro/types";
import AuthorCard from "@/components/organisms/AuthorCard.astro";
import type Author from "@/core/author/author.model";
import { cn } from "@/lib/utils";

interface Props extends HTMLAttributes<"div"> {
	author: Author;
}
const { author, ...attrs } = Astro.props;
const { name, email, avatar, bio, location, socials } = author;
---

<div class={cn("author-hero", attrs.class)} {...attrs}>
    <div class="author-hero__content">
        <AuthorCard
            name={name}
            email={email}
            avatar={avatar}
            location={location}
            socials={socials}
        />
        <p class="author-hero__bio">{bio}</p>
    </div>
</div>
