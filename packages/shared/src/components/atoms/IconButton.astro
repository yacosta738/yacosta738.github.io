---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@/lib/utils";

export interface Props extends HTMLAttributes<"button"> {}
const { class: className, ...attrs } = Astro.props;
---

<button
  class={cn(
    "ui-icon-button",
    className
  )}
    {...attrs}
>
  <slot />
</button>
