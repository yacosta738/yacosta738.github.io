---
import type { HTMLAttributes } from "astro/types";
import { routes } from "@/configs/route.path";
import { getTagSlug } from "@/core/tag";
import type Tag from "@/core/tag/tag.model";
import { type Lang, useTranslatedPath, useTranslations } from "@/i18n";
import { cn } from "@/lib/utils";

interface Props extends HTMLAttributes<"a"> {
	tag: Tag;
	currentLocale: Lang;
}
const { tag, type, currentLocale, ...attrs } = Astro.props;

const translatePath = useTranslatedPath(currentLocale);
---

<a
	class={cn(
		"inline-flex items-center min-h-6 px-2 py-1 rounded-sm w-fit text-[11px] tracking-widest uppercase transition-colors hover:opacity-80 focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none",
		attrs.class
	)}
	href={translatePath(
		`/${routes.tag}/${getTagSlug(tag).toLowerCase()}/`,
	)}
	{...attrs}
>
	{tag.title}
</a>
