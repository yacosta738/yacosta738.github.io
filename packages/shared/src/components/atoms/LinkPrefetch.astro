---
/**
 * LinkPrefetch component - Initializes intelligent link prefetching
 *
 * Usage: Add to your layout file
 * <LinkPrefetch />
 *
 * Or with custom options:
 * <LinkPrefetch
 *   hoverDelay={150}
 *   selector="a[href^='/']:not([data-no-prefetch])"
 *   priority="high"
 * />
 */

interface Props {
	/**
	 * Delay before starting prefetch (ms)
	 * Default: 100ms
	 */
	hoverDelay?: number;

	/**
	 * CSS selector for links to prefetch
	 * Default: 'a[href^="/"]' (all internal links)
	 */
	selector?: string;

	/**
	 * Maximum concurrent prefetches
	 * Default: 3
	 */
	maxConcurrent?: number;

	/**
	 * Prefetch on touchstart for mobile
	 * Default: true
	 */
	prefetchOnTouch?: boolean;

	/**
	 * Prefetch priority
	 * Default: 'low'
	 */
	priority?: "high" | "low" | "auto";

	/**
	 * Enable debug logging
	 * Default: false
	 */
	debug?: boolean;
}

const {
	hoverDelay = 100,
	selector = 'a[href^="/"]',
	maxConcurrent = 3,
	prefetchOnTouch = true,
	priority = "low",
	debug = false,
} = Astro.props;

const config = {
	hoverDelay,
	selector,
	maxConcurrent,
	prefetchOnTouch,
	priority,
	debug,
};

const serializedConfig = JSON.stringify(config);
---

<script id="link-prefetch-config" type="application/json" set:html={serializedConfig}></script>

<script>
  import { initLinkPrefetch, getPrefetchStats } from '../../utils/link-prefetch';

  function readConfig() {
    const el = document.getElementById('link-prefetch-config');
    if (!el?.textContent) return null;
    try { return JSON.parse(el.textContent); } catch { return null; }
  }

  let cleanup: (() => void) | null = null;
  let debugTimer: ReturnType<typeof setInterval> | null = null;

  function initPrefetch() {
    cleanup?.();
    if (debugTimer) { clearInterval(debugTimer); debugTimer = null; }

    const cfg = readConfig() ?? {
      hoverDelay: 100, selector: 'a[href^="/"]', maxConcurrent: 3,
      prefetchOnTouch: true, priority: 'low' as const, debug: false,
    };

    cleanup = initLinkPrefetch({
      hoverDelay: cfg.hoverDelay,
      selector: cfg.selector,
      maxConcurrent: cfg.maxConcurrent,
      prefetchOnTouch: cfg.prefetchOnTouch,
      priority: cfg.priority,
    });

    if (cfg.debug) {
      debugTimer = setInterval(() => console.log('[Prefetch Stats]', getPrefetchStats()), 5000);
    }
  }

  window.addEventListener('beforeunload', () => { cleanup?.(); if (debugTimer) clearInterval(debugTimer); });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPrefetch, { once: true });
  } else {
    initPrefetch();
  }

  document.addEventListener('astro:page-load', initPrefetch);
</script>
