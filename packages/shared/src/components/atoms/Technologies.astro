---
/**
 * Technologies component.
 * This component creates a dynamic background effect featuring floating technology
 * icons. It fetches a list of skills, filters for those with icons, and then
 * uses a client-side script to randomly animate them across the viewport.
 * The animation is purely decorative and does not accept any props.
 */
import { Icon } from "astro-icon/components";
import { getSkills } from "@/core/skill";
import type Skill from "@/core/skill/skill-library.model";

const techData = await getSkills({ icon: true });

const techs: Skill[] = techData.filter(
	(tech) => tech.icon !== undefined && tech.icon !== null,
);
---

<div class="fixed inset-0 -z-10 pointer-events-none">
	<div
		id="icons"
		class="relative h-full w-full"
	>
		{techs.map((tech) => (
			<Icon 
				name={tech.icon} 
				class="absolute h-24 w-24 fill-current p-4 opacity-0 tech-icon" 
			/>
		))}
	</div>
</div>
<script>
	(function() {
		// Respect reduced motion preference - skip animation entirely
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) return;

		function initAnimation() {
			const iconsContainer = document.getElementById('icons');
			if (!iconsContainer) return;
			const techIcons = Array.from(iconsContainer.querySelectorAll('.tech-icon') ?? []);
			if (techIcons.length === 0) return;

			// Disable animation on low-end devices / slow connections
			const isLowEnd = navigator.connection?.saveData === true ||
				(navigator.connection?.effectiveType === 'slow-2g' || navigator.connection?.effectiveType === '2g');
			if (isLowEnd) return;

			const w = window.innerWidth;
			const h = window.innerHeight;
			let intervalId = null;

			function animateIcon() {
				const available = techIcons.filter((icon) => !icon.getAttribute('data-is-animating'));
				if (available.length === 0) return;

				const iconToAnimate = available[Math.floor(Math.random() * available.length)];

				iconToAnimate.addEventListener('animationend', () => {
					iconToAnimate.classList.remove('animate-moving-background');
					iconToAnimate.removeAttribute('style');
					iconToAnimate.removeAttribute('data-is-animating');
				}, { once: true });

				const x = Math.floor(Math.random() * (w - 96));
				const y = Math.floor(Math.random() * (h - 96));
				iconToAnimate.setAttribute('style', `top: ${y}px; left: ${x}px;`);
				iconToAnimate.classList.add('animate-moving-background');
				iconToAnimate.setAttribute('data-is-animating', 'true');
			}

			function scheduleAnimation() {
				// Use requestIdleCallback when available to avoid blocking main thread
				if ('requestIdleCallback' in window) {
					requestIdleCallback(animateIcon, { timeout: 500 });
				} else {
					setTimeout(animateIcon, 0);
				}
			}

			// Start animation, then repeat every 3s (was 2s)
			scheduleAnimation();
			intervalId = setInterval(scheduleAnimation, 3000);
		}

		// Wait for page load, then give astro-icon time to render
		// Init on Astro page-load lifecycle (works with client navigation too)
		document.addEventListener('astro:page-load', () => {
			setTimeout(initAnimation, 2000);
		});
	})();
</script>
