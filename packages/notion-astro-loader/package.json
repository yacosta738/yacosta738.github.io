{
	"name": "@yap/astro-notion-loader",
	"version": "1.1.12",
	"description": "Astro Content Loader to use Notion as a CMS",
	"keywords": [
		"astro-loader",
		"astro",
		"notion",
		"cms"
	],
	"homepage": "https://github.com/yacosta738/yacosta738.github.io",
	"bugs": {
		"url": "https://github.com/yacosta738/yacosta738.github.io/issues"
	},
	"repository": "github:yacosta738/yacosta738.github.io",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		},
		"./schemas": {
			"import": "./src/schemas/index.ts",
			"types": "./src/schemas/index.ts"
		},
		"./schemas/raw-properties": {
			"import": "./src/schemas/raw-properties.ts",
			"types": "./src/schemas/raw-properties.ts"
		},
		"./schemas/transformed-properties": {
			"import": "./src/schemas/transformed-properties.ts",
			"types": "./src/schemas/transformed-properties.ts"
		},
		"./schemas/page": {
			"import": "./src/schemas/page.ts",
			"types": "./src/schemas/page.ts"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsc --build",
		"build:watch": "tsc --watch",
		"clean": "crossrm dist tsconfig.tsbuildinfo",
		"prepublishOnly": "pnpm run build",
		"test": "echo 'No tests available'"
	},
	"dependencies": {
		"@jsdevtools/rehype-toc": "catalog:",
		"@notionhq/client": "catalog:",
		"fs-extra": "catalog:",
		"kleur": "catalog:",
		"notion-rehype-k": "catalog:",
		"rehype-katex": "catalog:",
		"rehype-slug": "catalog:",
		"rehype-stringify": "catalog:",
		"slug": "catalog:",
		"unified": "catalog:",
		"unist-util-visit": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/fs-extra": "catalog:",
		"@types/slug": "catalog:",
		"astro": "catalog:",
		"crossrm": "catalog:",
		"typescript": "catalog:",
		"vfile": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"astro": ">=6.1.4"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.22.2"
	}
}
