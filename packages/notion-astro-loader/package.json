{
	"name": "@yap/astro-notion-loader",
	"version": "1.1.4",
	"description": "Astro Content Loader to use Notion as a CMS",
	"keywords": [
		"astro-loader",
		"astro",
		"notion",
		"cms"
	],
	"homepage": "https://github.com/yacosta738/yacosta738.github.io",
	"bugs": {
		"url": "https://github.com/yacosta738/yacosta738.github.io/issues"
	},
	"repository": "github:yacosta738/yacosta738.github.io",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		},
		"./schemas": {
			"import": "./src/schemas/index.ts",
			"types": "./src/schemas/index.ts"
		},
		"./schemas/raw-properties": {
			"import": "./src/schemas/raw-properties.ts",
			"types": "./src/schemas/raw-properties.ts"
		},
		"./schemas/transformed-properties": {
			"import": "./src/schemas/transformed-properties.ts",
			"types": "./src/schemas/transformed-properties.ts"
		},
		"./schemas/page": {
			"import": "./src/schemas/page.ts",
			"types": "./src/schemas/page.ts"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsc --build",
		"build:watch": "tsc --watch",
		"clean": "crossrm dist tsconfig.tsbuildinfo",
		"prepublishOnly": "pnpm run build",
		"test": "echo 'No tests available'"
	},
	"dependencies": {
		"@jsdevtools/rehype-toc": "^3.0.2",
		"@notionhq/client": "^5.14.0",
		"fs-extra": "^11.3.4",
		"kleur": "^4.1.5",
		"notion-rehype-k": "^1.1.6",
		"rehype-katex": "^7.0.1",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.0",
		"slug": "^11.0.1",
		"unified": "^11.0.0",
		"unist-util-visit": "^5.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/slug": "^5.0.9",
		"astro": "6.0.8",
		"crossrm": "^1.0.0",
		"prettier": "^3.5.3",
		"typescript": "^6.0.2",
		"vfile": "^6.0.3",
		"vitest": "^4.1.1"
	},
	"peerDependencies": {
		"astro": ">=5.15.9"
	},
	"packageManager": "pnpm@10.7.1+sha512.2d92c86b7928dc8284f53494fb4201f983da65f0fb4f0d40baafa5cf628fa31dae3e5968f12466f17df7e97310e30f343a648baea1b9b350685dafafffdf5808",
	"engines": {
		"node": ">=18"
	}
}
